PORT=3001
# Orígenes permitidos (sin barra final). Puedes usar uno o varios separados por coma.
CORS_ORIGIN=http://localhost:5173
CORS_ORIGINS=https://agro-app-mqek.vercel.app,http://localhost:5173
# En Vercel: también acepta previews https://agro-app-*.vercel.app (poner false para desactivar)
CORS_ALLOW_VERCEL_PREVIEWS=true

# Clever Cloud MySQL (automáticas al vincular el add-on)
MYSQL_ADDON_HOST=localhost
MYSQL_ADDON_PORT=3306
MYSQL_ADDON_DB=agroapp
MYSQL_ADDON_USER=root
MYSQL_ADDON_PASSWORD=

# Clever Cloud: max_user_connections suele ser 5.
# En Vercel (VERCEL=1) el backend usa una conexión por consulta y cola interna (automático).
# MYSQL_PER_REQUEST=true  # forzar también en local
# MYSQL_POOL_LIMIT=4      # solo desarrollo local (pool)

# Cuenta de desarrollador (no se guarda en BD con contraseña en claro)
DEVELOPER_CEDULA=1036401824
DEVELOPER_PASSWORD=12041396
DEVELOPER_NOMBRE=Martin
DEVELOPER_APELLIDO=Arbelaez

# Sesiones (días)
SESSION_TTL_DAYS=7
