{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev: Vite",
      "type": "shell",
      "command": "npm run dev:clean",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE v",
          "endsPattern": "localhost:5173"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Abrir Simple Browser",
      "type": "shell",
      "command": "echo Abriendo http://localhost:5173/ — Si no se abre solo, usa Ctrl+Shift+P → Simple Browser: Show",
      "dependsOn": ["dev: Vite"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "build",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
