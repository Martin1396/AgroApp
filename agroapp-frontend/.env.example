# Copia a .env.local solo si quieres sobreescribir algo en tu máquina.
#
# Por defecto ya están definidos:
#   .env.development  → npm run dev   (API local vía proxy /api)
#   .env.production   → npm run build (API en Vercel)
#
# Desarrollo directo al backend (sin proxy):
# VITE_API_URL=http://localhost:3001/api

VITE_API_URL=/api
